# Gestalt - AI Prompt Compiler
# 环境变量配置

# ============================================
# ModelScope API 配置 (服务器端)
# ============================================

# ModelScope API Key (必需 - 用于魔搭部署)
# 在魔搭创空间中通过环境变量配置
MODELSCOPE_API_KEY=your_modelscope_api_key_here

# ModelScope API Base URL (可选)
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# ============================================
# 客户端默认配置 (可选)
# ============================================

# 默认 API 基础 URL
NEXT_PUBLIC_DEFAULT_BASE_URL=https://api-inference.modelscope.cn/v1

# 默认模型
NEXT_PUBLIC_DEFAULT_MODEL=Qwen/Qwen2.5-72B-Instruct
