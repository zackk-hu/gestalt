# Prompt Optimizer - AI 提示词优化器
# 环境变量配置

# ============================================
# DeepSeek API 配置 (服务器端)
# ============================================

# DeepSeek API Key (必需)
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API Base URL (可选)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ============================================
# 客户端默认配置 (可选)
# ============================================

# 默认 API 基础 URL
NEXT_PUBLIC_DEFAULT_BASE_URL=https://api.deepseek.com/v1

# 默认模型
NEXT_PUBLIC_DEFAULT_MODEL=deepseek-chat
